# =========================
# Database / SQL / Docker
# =========================

# 数据库真实数据不要提交
mysql_data/
db_data/
data/mysql/

*.db
*.sqlite
*.sqlite3

# 数据库导出文件通常较大，谨慎提交
*.sql.gz
*.dump

# 如果是初始化 SQL，可以提交
!sql/init/*.sql
!sql/**/*.sql

# Docker 本身配置可以提交
!docker-compose.yml
!docker-compose.yaml
!Dockerfile

# 本地 Docker override 不提交
docker-compose.override.yml
docker-compose.local.yml

