# =========================
# 环境变量配置模板
# 复制本文件为 .env 后按本机环境修改。
# 不要把真实 .env 或真实 API Key 提交到 Git。
# =========================

MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=community_service
MYSQL_USER=appuser
MYSQL_PASSWORD=app_password_123

MYSQL_HOST=localhost
MYSQL_PORT=3306

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

COMPOSE_PROJECT_NAME=community-service

JWT_SECRET=change_me_to_a_long_random_secret

AI_API_KEY=
AI_API_URL=

# 阿里云百炼 / DashScope OCR 预审配置
# 本地 .env 中填写真实 Key；示例文件只保留占位值。
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_OCR_MODEL=qwen-vl-ocr-latest
DASHSCOPE_OCR_ENABLED=true

# 材料文件上传目录
MATERIAL_UPLOAD_DIR=uploads/materials

NGINX_PORT=80
